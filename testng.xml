<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Capstone Suite" parallel="false">

    <!-- Smoke: quick sanity - verifies app is up and login works -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <!-- Regression: full My Info module validation in order -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="tests.MyInfoTest"/>
            <class name="tests.UploadImageTest"/>
            <class name="tests.ContactDetailsTest"/>
            <class name="tests.EmergencyContactTest"/>
            <class name="tests.DependentsTest"/>
            <!-- Persistence always runs last - depends on above data -->
            <class name="tests.ProfilePersistenceTest"/>
        </classes>
    </test>

</suite>
